# URL do banco Postgres (Render fornece isso no painel do banco)
# Formato psycopg3: postgresql+psycopg://user:password@host:5432/dbname
DATABASE_URL=postgresql+psycopg://user:password@host:5432/dbname

# Origens permitidas no CORS (separadas por vírgula dentro do JSON)
CORS_ORIGINS=["https://seu-frontend.onrender.com"]

# URL da API usada pelo frontend
VITE_API_URL=https://seu-backend.onrender.com/api
