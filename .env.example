# ─── Banco de dados ───────────────────────────────────────────────────────────
# Local (docker-compose com postgres rodando na máquina):
DATABASE_URL=postgresql+psycopg://fluxo:fluxo@localhost:5432/fluxo_pessoal

# Render (substitua pela Internal Database URL do painel, trocando o prefixo):
# DATABASE_URL=postgresql+psycopg://user:password@host:5432/dbname

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["*"]

# ─── Frontend ─────────────────────────────────────────────────────────────────
# Como o frontend é servido pelo próprio backend, /api funciona em qualquer ambiente.
# Só defina isso se o frontend estiver em domínio diferente do backend.
# VITE_API_URL=https://<nome-do-seu-backend>.onrender.com/api
